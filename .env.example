# Copy to .env and fill in values
NODE_ENV=development
DOMAIN=schoolerp.com
SSL_EMAIL=admin@schoolerp.com

# Database
DB_USER=postgres
DB_PASSWORD=your_strong_password
CENTRAL_DATABASE_URL=postgresql://postgres:your_strong_password@localhost:5432/school_erp_central

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT (generate with: openssl rand -hex 32)
JWT_SECRET=generate_32_char_secret_here
JWT_REFRESH_SECRET=generate_another_32_char_secret

# S3 Storage
S3_ENDPOINT=https://s3.ap-south-1.amazonaws.com
S3_REGION=ap-south-1
S3_BUCKET=school-erp-media
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key

# SMTP Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password

# Razorpay (optional)
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=your_secret

# Firebase (push notifications)
FIREBASE_PROJECT_ID=your_project
FIREBASE_CLIENT_EMAIL=firebase@project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=your_private_key

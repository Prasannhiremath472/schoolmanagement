# Application
NODE_ENV=development
PORT=4000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Central Database (Platform-level)
CENTRAL_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/school_erp_central?schema=public

# Per-School Database Connection
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres

# School Demo DB URL (used by seed scripts)
SCHOOL_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/school_demo_school_db?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=school-erp-jwt-secret-key-change-in-production-2024
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=school-erp-refresh-secret-key-change-in-production-2024
JWT_REFRESH_EXPIRES_IN=7d

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Email (SMTP) - configure your real SMTP for production
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=School ERP <noreply@schoolerp.com>

# S3 Storage (configure for real file uploads)
STORAGE_PROVIDER=s3
S3_ENDPOINT=https://s3.ap-south-1.amazonaws.com
S3_REGION=ap-south-1
S3_BUCKET=school-erp-media
S3_ACCESS_KEY=your-s3-access-key
S3_SECRET_KEY=your-s3-secret-key
MAX_FILE_SIZE_MB=50

# Firebase Push Notifications (configure for real push)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=your-private-key

# Payment Gateways (configure for real payments)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

STRIPE_PUB_KEY=pk_test_your_stripe_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# SMS/WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_FROM_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=+14155238886

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback
